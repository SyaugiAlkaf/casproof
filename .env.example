# Casper testnet
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
CASPER_CHAIN_RPC=https://node.testnet.casper.network/rpc

# CSPR.cloud (free API key from console.cspr.cloud) — used for event reads in verify
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_BASE=https://api.testnet.cspr.cloud

# Producer / consumer agent keys (paths to secret key PEM files, never commit the PEMs)
# The deployer key (PRODUCER_KEY_PATH) is the registry owner and quorum agent 0.
PRODUCER_KEY_PATH=./keys/producer_secret_key.pem
CONSUMER_KEY_PATH=./keys/consumer_secret_key.pem
KEY_ALGORITHM=ed25519

# Multi-model quorum panel. QUORUM_THRESHOLD = k (distinct agreeing signers required).
# Each model agent signs with its own key; `npm run keygen:quorum` makes them, fund each once.
# Override the panel with QUORUM_MODELS="modelId:keyPath,modelId:keyPath" (default = 3 agents).
QUORUM_THRESHOLD=3
QUORUM_MODELS=
REQUEST_ID=                    # leave empty to derive a fresh request per run
ADMIN_PAYMENT_MOTES=2000000000

# Deployed registry contract: the bare hex contract hash (no hash-/contract- prefix).
# After `npm run deploy`, run `npm run resolve` to print this, or read it off cspr.live.
REGISTRY_CONTRACT_HASH=
REGISTRY_PACKAGE_HASH=          # registry PACKAGE hash (from `npm run resolve`); needed to deploy the vault
WASM_PATH=../contract/wasm/AttestationRegistry.wasm
EXPLORER_BASE=https://testnet.cspr.live

# On-chain verify-gate (PayoutVault). Deploy with `npm run deploy:vault` (needs REGISTRY_PACKAGE_HASH),
# then `npm run resolve:vault` to print VAULT_CONTRACT_HASH.
VAULT_CONTRACT_HASH=
VAULT_WASM_PATH=../contract/wasm/PayoutVault.wasm
VAULT_PAYMENT_MOTES=5000000000

# payment in motes (1 CSPR = 1e9 motes); bump install if "Out of Gas"
INSTALL_PAYMENT_MOTES=400000000000
ATTEST_PAYMENT_MOTES=3000000000

# consumer trust policy: comma-separated trusted signer account-hashes; empty = trust any on-chain attestation
TRUSTED_SIGNERS=

# x402 facilitator (hosted) — metered verification reads
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_NETWORK=casper:casper-test
X402_MODE=sim                  # sim = local handshake (default, works out of the box); live = settle via the hosted facilitator (needs the Casper x402 signer + CSPR.cloud key)
X402_PORT=4021
X402_PAY_TO=                   # oracle operator account that earns per verified read
X402_ASSET=CSPR
X402_PRICE_MOTES=100000000     # 0.1 CSPR per verify
X402_ENDPOINT=http://localhost:4021/verify
X402_PAYER=                    # consumer account paying for reads (public key / account hash)

# Anthropic (the AI whose output gets attested)
ANTHROPIC_API_KEY=
