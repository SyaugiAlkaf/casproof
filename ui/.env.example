# ── Server-side (chain reads happen in app/api/verify; never exposed to the browser) ──

# Casper testnet RPC the verify API reads from. Either var works; CASPER_CHAIN_RPC wins.
CASPER_CHAIN_RPC=https://node.testnet.casper.network/rpc
# CASPER_NODE_URL=https://node.testnet.casper.network/rpc

# Deployed AttestationRegistry: bare hex hash (no hash-/contract- prefix). From `npm run resolve`
# in ../agents after deploying. Unset => API returns the computed hash with attested:false + a note.
REGISTRY_CONTRACT_HASH=

# Deployed PayoutVault: bare hex hash. From `npm run resolve:vault`. Optional; used for explorer links.
VAULT_CONTRACT_HASH=

# Shared request id the producer agents attested under (`npm run demo`/`producer` print it, or
# set it there first). The verify API reads quorum/agreement for this request when no requestId is posted.
REQUEST_ID=

# k that setup.ts wrote on-chain via set_quorum; used only as the dashboard's "k / n agree"
# denominator (the PAY/BLOCK decision uses quorum_output, not this number). Unset => no denominator.
QUORUM_THRESHOLD=

# Explorer base for the verify API's contract links.
EXPLORER_BASE=https://testnet.cspr.live

# Optional: comma-separated trusted signer account-hashes. Empty = trust any on-chain attestation.
TRUSTED_SIGNERS=

# Optional CSPR.cloud key — enables the events-index fallback when a direct state read can't resolve.
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_BASE=https://api.testnet.cspr.cloud

# ── Client-side (NEXT_PUBLIC_*, inlined at build time, safe to ship to the browser) ──

# Same explorer base, for client-rendered tx/contract links.
NEXT_PUBLIC_EXPLORER_BASE=https://testnet.cspr.live

# Registry/vault hashes for client-rendered "view on explorer" links + the live/illustrative badge.
NEXT_PUBLIC_REGISTRY_CONTRACT_HASH=
NEXT_PUBLIC_VAULT_CONTRACT_HASH=

# Request id the dashboard reads quorum state for. Must match REQUEST_ID above for live numbers.
NEXT_PUBLIC_REQUEST_ID=

# Same k as QUORUM_THRESHOLD, for client-rendered "k / n agree" display. Falls back to the server var.
NEXT_PUBLIC_QUORUM_THRESHOLD=

# Real testnet deploy hashes from `npm run demo`/`producer`/consumer in ../agents (human-gated;
# leave blank until a deploy actually happens — never fabricate). Rendered as EXPLORER_BASE/deploy/<hash>.
NEXT_PUBLIC_ATTEST_TX_HASH=
NEXT_PUBLIC_PAYOUT_TX_HASH=
NEXT_PUBLIC_BLOCKED_TX_HASH=
