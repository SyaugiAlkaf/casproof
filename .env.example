# Casper testnet
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
CASPER_CHAIN_RPC=https://node.testnet.casper.network/rpc

# CSPR.cloud (free API key from console.cspr.cloud) — used for event reads in verify
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_BASE=https://api.testnet.cspr.cloud

# Producer / consumer agent keys (paths to secret key PEM files, never commit the PEMs)
PRODUCER_KEY_PATH=./keys/producer_secret_key.pem
CONSUMER_KEY_PATH=./keys/consumer_secret_key.pem
KEY_ALGORITHM=ed25519

# Deployed registry contract: the bare hex contract hash (no hash-/contract- prefix).
# After `npm run deploy`, run `npm run resolve` to print this, or read it off cspr.live.
REGISTRY_CONTRACT_HASH=
WASM_PATH=../contract/wasm/AttestationRegistry.wasm
EXPLORER_BASE=https://testnet.cspr.live

# payment in motes (1 CSPR = 1e9 motes); bump install if "Out of Gas"
INSTALL_PAYMENT_MOTES=400000000000
ATTEST_PAYMENT_MOTES=3000000000

# consumer trust policy: comma-separated trusted signer account-hashes; empty = trust any on-chain attestation
TRUSTED_SIGNERS=

# x402 facilitator (hosted)
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_NETWORK=casper:casper-test

# Anthropic (the AI whose output gets attested)
ANTHROPIC_API_KEY=
