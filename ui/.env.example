# Casper testnet RPC the verify API reads from (server-side only).
# Either var name works; CASPER_CHAIN_RPC takes precedence.
CASPER_CHAIN_RPC=https://node.testnet.casper.network/rpc
# CASPER_NODE_URL=https://node.testnet.casper.network/rpc

# Deployed AttestationRegistry contract: bare hex hash (no hash-/contract- prefix).
# Get it from `npm run resolve` in ../agents after deploying. If unset, the API still
# returns the computed hash with attested:false and a "registry contract not configured" note.
REGISTRY_CONTRACT_HASH=

# Explorer base used to build "View attestation" links.
EXPLORER_BASE=https://testnet.cspr.live

# Optional: comma-separated trusted signer account-hashes. Empty = trust any on-chain attestation.
TRUSTED_SIGNERS=
